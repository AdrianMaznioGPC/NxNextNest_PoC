{
  "name": "bff",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "targets": {
    "dev": {
      "command": "npm run start:dev",
      "options": { "cwd": "apps/bff" }
    },
    "build": {
      "command": "tsc -p tsconfig.json",
      "options": { "cwd": "apps/bff" }
    },
    "start": {
      "dependsOn": ["build"],
      "command": "node dist/apps/bff/src/main.js",
      "options": { "cwd": "apps/bff" }
    },
    "test": {
      "command": "node --import tsx --test 'src/**/*.spec.ts'",
      "options": { "cwd": "apps/bff" }
    }
  }
}
