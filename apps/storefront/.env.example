COMPANY_NAME="Vercel Inc."
SITE_NAME="Next.js Commerce"
BFF_URL="http://localhost:4000"
REVALIDATION_SECRET="replace-me"
NEXT_PUBLIC_CONSERVATIVE_PREFETCH="true"
NEXT_PUBLIC_DEFER_SHELL_INTERACTIONS="true"
NEXT_PUBLIC_CART_API_BASE="/api/cart"
# Theme assignment is BFF-driven via /i18n/domain-config (no storefront theme env var).
# Legacy variables from the original Shopify template (unused in this BFF-driven architecture):
# SHOPIFY_REVALIDATION_SECRET=""
# SHOPIFY_STOREFRONT_ACCESS_TOKEN=""
# SHOPIFY_STORE_DOMAIN="[your-shopify-store-subdomain].myshopify.com"
